<h2>Feedback Control Image Recovery Filter</h2>

<pre>
#!/usr/bin/env python3

import cv2
import numpy as np


class FastSpatialRGBWaterFilter:

    def __init__(
        self,
        target_rgb=(0.5, 0.5, 0.5),
        alpha=0.95,
        small_width=160,
        tile_size=10,
        gain_min=0.5,
        gain_max=2.5,
    ):

        self.target_rgb = np.array(target_rgb, dtype=np.float32)
        self.alpha = alpha
        self.small_width = small_width
        self.tile_size = tile_size
        self.gain_min = gain_min
        self.gain_max = gain_max

        self.gain_map_prev = None

    def apply_filter(self, frame_bgr):

        frame_rgb = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2RGB)
        frame = frame_rgb.astype(np.float32) / 255.0

        h, w = frame.shape[:2]

        scale = self.small_width / w
        small_h = int(h * scale)

        small = cv2.resize(
            frame,
            (self.small_width, small_h),
            interpolation=cv2.INTER_AREA
        )

        gain_map = np.zeros_like(small)

        for y in range(0, small_h, self.tile_size):
            for x in range(0, self.small_width, self.tile_size):

                tile = small[
                    y:y+self.tile_size,
                    x:x+self.tile_size
                ]

                mean_rgb = tile.mean(axis=(0, 1))

                gain = self.target_rgb / (mean_rgb + 1e-6)

                gain = np.clip(
                    gain,
                    self.gain_min,
                    self.gain_max
                )

                gain_map[
                    y:y+self.tile_size,
                    x:x+self.tile_size
                ] = gain

        if self.gain_map_prev is None:
            smoothed_gain = gain_map
        else:
            smoothed_gain = (
                self.alpha * self.gain_map_prev
                + (1.0 - self.alpha) * gain_map
            )

        self.gain_map_prev = smoothed_gain.copy()

        smoothed_gain = cv2.GaussianBlur(
            smoothed_gain,
            (11, 11),
            0
        )

        gain_full = cv2.resize(
            smoothed_gain,
            (w, h),
            interpolation=cv2.INTER_LINEAR
        )

        corrected = frame * gain_full

        corrected = np.clip(corrected, 0.0, 1.0)

        corrected_uint8 = (corrected * 255).astype(np.uint8)

        corrected_bgr = cv2.cvtColor(
            corrected_uint8,
            cv2.COLOR_RGB2BGR
        )

        return corrected_bgr
